
import os
import discord
from discord.ext import commands

intents = discord.Intents.default()
intents.members = True
intents.message_content = True

bot = commands.Bot(command_prefix="!", intents=intents)

@bot.event
async def on_ready():
    print(f"Prisijunge kaip {bot.user}")

@bot.command()
async def zmones(ctx):
    guild = ctx.guild
    members = guild.members

    msg = f"**Serveryje yra {len(members)} zmoniu:**\n\n"
    for member in members:
        roles = [role.name for role in member.roles if role.name != "@everyone"]
        roles_str = ", ".join(roles) if roles else "Nera roliu"
        msg += f"**{member.display_name}** - {roles_str}\n"

    if len(msg) > 2000:
        for chunk in [msg[i:i+1990] for i in range(0, len(msg), 1990)]:
            await ctx.send(chunk)
    else:
        await ctx.send(msg)

bot.run(os.environ["TOKEN"])
